{
	"name": "ngx-command-palette-workspace",
	"version": "0.0.0",
	"private": true,
	"packageManager": "pnpm@11.3.0",
	"scripts": {
		"ng": "ng",
		"build:lib": "ng build ngx-command-palette --configuration production && pnpm run build:schematics && cp README.md dist/ngx-command-palette/README.md",
		"build:schematics": "tsc -p projects/ngx-command-palette/tsconfig.schematics.json",
		"build:demo": "ng build demo",
		"start": "pnpm run build:lib && ng serve demo",
		"test": "vitest",
		"test:ci": "vitest run",
		"lint": "ng lint",
		"lint:fix": "ng lint --fix",
		"prepare": "husky"
	},
	"dependencies": {
		"@angular/animations": "~20.3.0",
		"@angular/cdk": "~20.2.0",
		"@angular/common": "~20.3.0",
		"@angular/compiler": "~20.3.0",
		"@angular/core": "~20.3.0",
		"@angular/forms": "~20.3.0",
		"@angular/platform-browser": "~20.3.0",
		"@angular/platform-browser-dynamic": "~20.3.0",
		"@angular/router": "~20.3.0",
		"rxjs": "~7.8.0",
		"tslib": "^2.3.0"
	},
	"lint-staged": {
		"*.ts": "eslint --fix",
		"*.html": "eslint --fix"
	},
	"devDependencies": {
		"@analogjs/vite-plugin-angular": "^2.6.1",
		"@angular-devkit/build-angular": "~20.3.0",
		"@angular-devkit/core": "^20.3.0",
		"@angular-devkit/schematics": "^20.3.0",
		"@angular-eslint/builder": "^20.7.0",
		"@angular-eslint/eslint-plugin": "^20.7.0",
		"@angular-eslint/eslint-plugin-template": "^20.7.0",
		"@angular-eslint/schematics": "^20.7.0",
		"@angular-eslint/template-parser": "^20.7.0",
		"@angular/cli": "~20.3.0",
		"@angular/compiler-cli": "~20.3.0",
		"@schematics/angular": "^20.3.0",
		"@types/node": "^22.0.0",
		"@typescript-eslint/eslint-plugin": "^8.33.1",
		"@typescript-eslint/parser": "^8.33.1",
		"angular-eslint": "^20.7.0",
		"eslint": "^9.28.0",
		"husky": "^9.1.7",
		"jsdom": "^29.1.1",
		"lint-staged": "^15.5.2",
		"ng-packagr": "~20.3.0",
		"typescript": "~5.8.3",
		"vitest": "^4.0.8",
		"zone.js": "~0.15.1"
	}
}
